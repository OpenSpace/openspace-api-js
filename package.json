{
  "name": "openspace-api-js",
  "version": "0.1.6",
  "description": "OpenSpace Socket/Websocket API bindings for JavaScript",
  "main": "dist/node.js",
  "types": "dist/types/node.d.ts",
  "browser": {
    "./src/node.js": "./dist/browser.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.json && rollup --config rollup.config.ts --configPlugin typescript",
    "example": "npx ts-node examples/example.ts",
    "typecheck": "tsc --noEmit"
  },
  "author": "OpenSpace Team",
  "license": "MIT",
  "repository": "https://github.com/OpenSpace/openspace-api-js",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  }
}
