{
  "name": "openspace-api-js",
  "version": "1.0.0",
  "description": "OpenSpace Socket/Websocket API bindings for JavaScript",
  "main": "./dist/node.js",
  "browser": {
    "./dist/node.js": "./dist/browser.js"
  },
  "types": "./dist/node.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.js",
      "browser": "./dist/browser.js",
      "default": "./dist/node.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.js"
    },
    "./topics": {
      "require": "./dist/topic.js",
      "import": "./dist/topic.js",
      "types": "./dist/topic.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.json && rollup --config rollup.config.ts --configPlugin typescript",
    "typecheck": "tsc --noEmit",
    "generate-lua-library": "pip install -r script/requirements.txt && python script/generatetypescriptfile.py",
    "generate-topic-types": "node script/generatetopictypes.mjs",
    "examples-javascript": "node examples/example.js",
    "examples-typescript": "npx ts-node examples/example.ts"
  },
  "author": "OpenSpace Team",
  "license": "MIT",
  "repository": "https://github.com/OpenSpace/openspace-api-js",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  }
}
